{
  "version": "1.0.0",
  "description": "股票大师 daily_run_skill 外置配置",

  "mss_weights": {
    "fx": 0.3,
    "flow": 0.3,
    "global": 0.2,
    "sentiment": 0.2
  },

  "lookback_weights": [0.5, 0.3, 0.2],

  "thresholds": {
    "macro_veto": 40,
    "aggressive_entry": 50,
    "min_cash_ratio": 0.4,
    "max_price_deviation_pct": 0.08,
    "max_snapshot_age_hours": 24,
    "high_position_20d": 0.7,
    "low_position_20d": 0.4,
    "min_volume_ratio": 1.0,
    "max_vwap_deviation_pct": 0.04
  },

  "buffett_filter": {
    "min_gross_margin": 0.35,
    "max_peg": 1.2,
    "min_roe": 0.15
  },

  "trading": {
    "commission_rate": 0.0015,
    "slippage_rate": 0.001,
    "stop_loss_ma20_pct": 0.04,
    "holding_lock_days": 3
  },

  "quality_gate": {
    "required_fields": [
      "verdict",
      "confidence",
      "mss_final",
      "reasoning",
      "invalidation",
      "evidence_chain"
    ],
    "block_push_on_fail": true,
    "allow_downgrade_on_missing_technical": true
  },

  "data_audit": {
    "required_source_categories": ["quote", "flow", "sentiment"],
    "block_on_audit_fail": true,
    "block_on_price_deviation": true,
    "close_block_on_audit_fail": true,
    "intraday_block_on_audit_fail": false,
    "min_quote_coverage_pct": 0.8,
    "quote_coverage_mode": "block",
    "required_doctor_channels": ["web", "xueqiu"]
  },

  "quote_fetch": {
    "sources": ["xueqiu", "akshare"],
    "max_retries": 2
  },

  "feishu": {
    "send_max_retries": 3,
    "send_backoff_seconds": [1, 2, 4],
    "fallback_plaintext_on_card_error": true
  },

  "verdict_labels": {
    "buy": "可做",
    "watch": "观察",
    "avoid": "回避"
  },

  "confidence_levels": ["高", "中", "低"],

  "report": {
    "split_push": true,
    "split_push_interval_seconds": 0.3,
    "morning_split_push": true,
    "close_split_push": true,
    "feishu_split_tables": true,
    "feishu_template_premarket": "orange",
    "feishu_template_intraday": "blue",
    "feishu_template_close": "purple",
    "feishu_template_verify": "purple",
    "feishu_template_weekly": "blue",
    "feishu_template_forecast": "blue",
    "weekly_split_push": true,
    "forecast_split_push": true
  },

  "weekly_report": {
    "enabled": true,
    "split_push": true,
    "exa_sector_research": true,
    "max_sector_queries": 3,
    "skill_learning": false
  },

  "week_forecast": {
    "enabled": true,
    "split_push": true,
    "exa_news_research": true,
    "max_news_queries": 2,
    "close_review": true,
    "reuse_weekly_digest_exa": true,
    "calibration_learning_rate": 0.15,
    "max_bias_pct": 3.0,
    "min_vol_scale": 0.6,
    "max_vol_scale": 1.6
  },

  "findskills": {
    "enabled": true,
    "result_limit": 3,
    "timeout": 45,
    "max_queries": 2
  },

  "akshare": {
    "enabled": true,
    "default_history_days": 60,
    "adjust": "qfq",
    "lookback_days": 20
  },

  "backtest": {
    "default_initial_capital": 100000,
    "commission_rate": 0.0015,
    "macro_veto": 40,
    "aggressive_entry": 50
  },

  "optimizer": {
    "macro_veto_grid": [38, 40, 42, 45],
    "aggressive_entry_grid": [48, 50, 52, 55],
    "default_objective": "excess_return",
    "mss_weight_grid": [
      {"fx": 0.3, "flow": 0.3, "global": 0.2, "sentiment": 0.2},
      {"fx": 0.25, "flow": 0.35, "global": 0.2, "sentiment": 0.2},
      {"fx": 0.35, "flow": 0.25, "global": 0.2, "sentiment": 0.2},
      {"fx": 0.2, "flow": 0.3, "global": 0.3, "sentiment": 0.2}
    ]
  },

  "plugins": {
    "enabled": [
      "fundamental",
      "technical",
      "quant",
      "risk",
      "macro",
      "industry",
      "sentiment",
      "identifier"
    ],
    "parallel": true,
    "channel_enrich": true,
    "exa_research_on_close": true,
    "max_exa_queries": 3,
    "exa_timeout": 45,
    "max_exa_queries_per_expert": 1
  },

  "team": {
    "enabled": false,
    "mode": "full_parallel",
    "experts": [
      "fundamental",
      "technical",
      "quant",
      "risk",
      "macro",
      "industry",
      "sentiment",
      "identifier"
    ],
    "parallel": true,
    "supervisor": true,
    "morning_team_first": false,
    "close_team_first": false,
    "intraday_experts": false
  },

  "macro_collector": {
    "enabled": true,
    "sentiment_post_limit": 5
  },

  "mss_forecast": {
    "simulations": 200,
    "base_spread": 8,
    "vol_multiplier": 6
  },

  "schedule": {
    "symbols_mode": "all",
    "symbol_push_mode": "merge_by_category",
    "symbol_push_interval_seconds": 0.5,
    "intraday_trade_enabled": true,
    "trade_min_scans": 3,
    "trade_every_n_scans": 2,
    "morning_doctor": true,
    "alert_after_consecutive_failures": 3
  },

  "trade_calendar": {
    "enabled": true,
    "skip_on_holiday": true
  },

  "experience": {
    "enabled": true,
    "max_rules": 50,
    "max_entries": 200
  }
}
